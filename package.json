{
  "name": "roblox-gamelab-2",
  "version": "0.1.0",
  "private": true,
  "description": "Rojo-synced Roblox action prototype inspired by World of Claudecraft.",
  "scripts": {
    "dev": "rojo serve roblox/default.project.json",
    "dev:alt": "rojo serve roblox/default.project.json --port 34873",
    "marketplace:dev": "node --watch apps/marketplace/server.mjs",
    "marketplace:build": "node apps/marketplace/scripts/export-static.mjs",
    "marketplace:check": "node apps/marketplace/scripts/check-catalog.mjs",
    "build": "rojo build roblox/default.project.json --output output/exports/claudecraft-action-arena.rbxlx",
    "format": "stylua roblox/src",
    "format:check": "stylua --check roblox/src"
  },
  "devDependencies": {
    "@johnnymorganz/stylua-bin": "2.5.2",
    "rojo": "1.0.3-rojo7.6.1"
  }
}
